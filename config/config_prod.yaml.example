# ── CloudDriveManager — Production Configuration ─────────────────────────────
# WARNING: Do NOT commit real credentials to this file.
# Use environment variables for all sensitive values:
#   CLOUD_DB_HOST, CLOUD_DB_PORT, CLOUD_DB_USER, CLOUD_DB_PASSWORD, CLOUD_DB_NAME
#   CLOUD_ENCRYPTION_SALT
#
# This file contains only non-sensitive production defaults.

database:
  host: "localhost"       # Override via CLOUD_DB_HOST
  port: 3306
  username: "root"        # Override via CLOUD_DB_USER
  password: ""            # REQUIRED: Set via CLOUD_DB_PASSWORD env var
  name: "cloud_drive_manager"

app:
  host: "127.0.0.1"
  port: 29312
  debug: false

encryption:
  salt: ""                # REQUIRED: Set via CLOUD_ENCRYPTION_SALT env var

logging:
  level: "WARNING"
  file: "log/app.log"
  format: "json"

cloud_drives:
  rclone_path: "rclone"
  timeout: 300
  max_concurrent_syncs: 5
  max_retry: 10
