[Unit]
Description=CloudDriveManager HTTP API Service
After=network.target
Wants=cloud-drive-manager-mcp.service

[Service]
Type=simple
WorkingDirectory=/opt/CloudDriveManager
Environment="CLOUD_ENV=prod"
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/CloudDriveManager/bin/cloud-drive-manager
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
LogsDirectory=cloud-drive-manager
RuntimeDirectory=cloud-drive-manager

[Install]
WantedBy=default.target
